# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# EAS local signing credentials (keystore + passwords) — never commit
/credentials/
credentials.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Firebase FCM client config (used for Android push; kept out of git like .env).
# For EAS cloud builds, commit it or add it as an EAS file secret instead.
google-services.json

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android
