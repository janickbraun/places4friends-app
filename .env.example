# Supabase — publishable/anon key (safe to expose; protected by RLS)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Sign-In — OAuth client IDs (Google Cloud console). The WEB client ID is
# the one Supabase's Google provider uses to verify the ID token; the iOS client
# ID is used by the native sign-in. The iOS reversed client ID must also be set
# as `iosUrlScheme` in the google-signin plugin config in app.json.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Google Maps SDK for Android (required by react-native-maps on Android)
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
