{
  "expo": {
    "name": "places4friends",
    "slug": "places4friends-mobile-app",
    "version": "1.0.1",
    "description": "Erstelle eine interaktive Karte mit deinen Freunden. Empfiehl Restaurants, Bars, Cafés und Aktivitäten ohne anonyme Reise-Bewertungen - direkt von deinen Freunden empfohlen.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "places4friendsmobileapp",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#226622",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.janickbraun.places4friends",
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:places4friends.com"],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Wir verwenden deinen Standort, um Orte in deiner Nähe auf der Karte anzuzeigen.",
        "NSPhotoLibraryUsageDescription": "Wir verwenden deine Fotos, um sie zu deinen Ortsempfehlungen hinzuzufügen.",
        "LSApplicationQueriesSchemes": [
          "comgooglemaps"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#226622",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.janickbraun.places4friends",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "places4friends.com", "pathPrefix": "/invite" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Wir verwenden deine Fotos, um sie zu deinen Ortsempfehlungen hinzuzufügen.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#226622",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#226622",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.810305884195-e0vdkon2l8c48jjbm9p7i3e6c6ttvmde"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true,
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#226622"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Wir gleichen deine Kontakte ab, um dir Freunde vorzuschlagen, die places4friends schon nutzen. Deine Kontakte verlassen dein Gerät dabei nicht."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7aa37549-374d-41ea-834c-ee7e36ede032"
      }
    },
    "owner": "janick"
  }
}
