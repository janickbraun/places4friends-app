{
  "expo": {
    "name": "places4friends",
    "slug": "places4friends-mobile-app",
    "version": "1.0.0",
    "description": "Erstelle eine interaktive Karte mit deinen Freunden. Empfiehl Restaurants, Bars, Cafés und Aktivitäten ohne anonyme Reise-Bewertungen - direkt von deinen Freunden empfohlen.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "places4friendsmobileapp",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#226622",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.janickbraun.places4friends"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#226622",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.janickbraun.places4friends",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Wir verwenden deine Fotos, um sie zu deinen Ortsempfehlungen hinzuzufügen.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#226622",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#226622",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.810305884195-e0vdkon2l8c48jjbm9p7i3e6c6ttvmde"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#226622"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7aa37549-374d-41ea-834c-ee7e36ede032"
      }
    },
    "owner": "janick"
  }
}
